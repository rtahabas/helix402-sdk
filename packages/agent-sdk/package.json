{
  "name": "@helix402/agent-sdk",
  "version": "0.1.0-beta.3",
  "description": "x402 payment SDK for AI agents — automatic HTTP 402 handling with managed wallets",
  "author": "Helix402",
  "license": "Apache-2.0",
  "homepage": "https://github.com/rtahabas/helix402-sdk/tree/main/packages/agent-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/rtahabas/helix402-sdk.git",
    "directory": "packages/agent-sdk"
  },
  "bugs": {
    "url": "https://github.com/rtahabas/helix402-sdk/issues"
  },
  "keywords": [
    "x402",
    "payment",
    "ai-agent",
    "usdc",
    "eip-3009",
    "base",
    "blockchain",
    "helix402"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./langchain": {
      "require": "./dist/langchain.js",
      "import": "./dist/langchain.js",
      "types": "./dist/langchain.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/*.map",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "axios": ">=1.0.0",
    "ethers": ">=6.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^1.1.39",
    "axios": "^1.8.0",
    "ethers": "^6.13.0",
    "zod": "^4.3.6"
  }
}
