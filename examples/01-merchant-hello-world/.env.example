PORT=4000

# Your merchant payout wallet (0x-prefixed address on Base Sepolia).
MERCHANT_WALLET=0x0000000000000000000000000000000000000000

# JWT verification key — must match the gateway's JWT_SECRET.
GATEWAY_JWT_SECRET=change-me-to-gateway-secret

# Hosted gateway URL. Replace with your own if self-hosting.
FACILITATOR_URL=https://api.rtahabas.com
