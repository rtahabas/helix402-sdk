{
  "name": "@helix402/sdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Helix402 SDKs: merchant middleware, agent client, and smart contracts for x402 payments",
  "license": "Apache-2.0",
  "homepage": "https://github.com/rtahabas/helix402-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/rtahabas/helix402-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/rtahabas/helix402-sdk/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test:unit && npm run test:contracts",
    "test:unit": "vitest run packages/merchant-sdk packages/agent-sdk",
    "test:contracts": "cd packages/contracts && npx hardhat test",
    "typecheck": "tsc --noEmit -p packages/merchant-sdk/tsconfig.json && tsc --noEmit -p packages/agent-sdk/tsconfig.json",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'packages/*/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}'",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
